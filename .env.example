# Pulse runs on mock data when optional values are missing.
# Copy this file to .env and fill in what you need for local development.

# ── Turso / libSQL database ───────────────────────────────────────────────
# Optional: if unset, the app falls back to mock data.
# Local dev: use a file URL, e.g. file:./local.db (no token needed).
# Remote Turso: use libsql://<your-db>.turso.io and an auth token.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Shared secret for protected ingestion / briefing endpoints ────────────
# Any long random string. Required to call /api/ga4 and /api/briefings/daily.
PULSE_INGEST_SECRET=

# ── AI daily briefing (OpenAI) ────────────────────────────────────────────
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# ── GA4 (Google Analytics Data API) ───────────────────────────────────────
# Per-product GA4 property IDs live in the metric_sources table (see README),
# NOT here. This section is only for service-account authentication.
# Choose ONE of the two credential styles:
#   1) Path to a service-account JSON key file:
GOOGLE_APPLICATION_CREDENTIALS=
#   2) Inline credentials (works on serverless, e.g. Vercel):
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Supabase (future) ─────────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Other future server-side connectors ───────────────────────────────────
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
FIREBASE_PROJECT_ID=
