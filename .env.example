# Pulse currently runs on mock data only.
# Add real values here later, then copy to .env for local development.

# Turso / libSQL database. Optional: if unset, the app falls back to mock data.
# Local dev: use a file URL, e.g. file:./local.db (no token needed).
# Remote Turso: use libsql://<your-db>.turso.io and an auth token.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Supabase, when persistence is introduced.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Future server-side connectors.
GA4_PROPERTY_ID=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
GOOGLE_CLOUD_PROJECT_ID=
FIREBASE_PROJECT_ID=

# Future AI daily briefing provider.
AI_PROVIDER=
AI_MODEL=
